# Start from Node 20 Alpine — lightweight ~7MB Linux with Node
# instead of full Ubuntu ~900MB. Backend only needs Node, not a full OS.
FROM node:20-alpine

# Create and set working directory inside the container
WORKDIR /app

# Copy package files first before source code.
# Docker caches layers — if dependencies haven't changed,
# npm ci is skipped on rebuild. Saves 40+ seconds every build.
COPY package.json package-lock.json ./

# Install exact versions from package-lock.json
# --only=production skips jest and nodemon — not needed in production
RUN npm ci --only=production

# Create non-root user before copying files.
# Never run containers as root — if exploited, attacker gets limited access.
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# Copy source code and assign ownership to appuser in one step
COPY --chown=appuser:appgroup . .

# Switch to non-root user
USER appuser

# Document that the app listens on port 3000
EXPOSE 3000

# Start the server — array syntax runs node directly without a shell,
# cleaner shutdown and faster signal handling than "node index.js" string form
CMD ["node", "index.js"]